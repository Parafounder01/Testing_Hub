      "id": 1,
      "title": "Waveguide Theory & Modes",
      "audio": "assets/audio/subject1/chap1.mp3",
      "duration": "25 mins",
      "keyPoints": [
        "What is Waveguide?",
        "TE/TM Modes",
        "Cutoff Frequency",
        "Phase vs Group Velocity"
      ],
      "content": "Hello student! Today we learn about Waveguides. A waveguide is like a pipe that carries microwaves from one place to another. Unlike regular wires, waveguides use the air inside metal pipes to guide electromagnetic waves.",
      "derivations": [
        {
          "title": "Telegrapher's Equations from Maxwell",
          "steps": [
            "Start with Maxwell's equations in phasor form",
            "Apply to coaxial line geometry",
            "Derive: ∂V/∂z = -(R+jωL)I",
            "Derive: ∂I/∂z = -(G+jωC)V",
            "Result: Wave equation ∂²V/∂z² = γ²V"
          ],
          "formula": "γ = √((R+jωL)(G+jωC)) [propagation constant]"
        },
        {
          "title": "Characteristic Impedance Z₀",
          "steps": [
            "For lossless line: R=0, G=0",
            "γ = jω√(LC)",
            "Z₀ = V+/I+ = √(L/C)",
            "For coaxial: Z₀ = (1/2π)√(μ/ε) × ln(b/a)"
          ],
          "formula": "Z₀ = √(L/C) = (60/√εᵣ) × ln(b/a) for coaxial"
        },
        {
          "title": "Cutoff Frequency for Rectangular Waveguide",
          "steps": [
            "For TE₁₀ mode in rectangular waveguide",
            "Cutoff wavelength λc = 2a (a = wider dimension)",
            "fc = c/λc = c/(2a)",
            "Higher modes have higher cutoff frequencies"
          ],
          "formula": "fc = c/(2a) for TE₁₀ mode"
        },
        {
          "title": "Phase and Group Velocity",
          "steps": [
            "Phase velocity: vp = ω/β",
            "Group velocity: vg = dω/dβ",
            "For waveguides: vp = c/√(1-(fc/f)²)",
            "vg = c×√(1-(fc/f)²)",
            "Note: vp × vg = c² (product constant)"
          ],
          "formula": "vp = fλg = ω/β, vg = dω/dβ = c√(1-(fc/f)²)"
        },
        {
          "title": "Waveguide Impedance",
          "steps": [
            "For TE modes: Z_w = β/(ωε) = η/√(1-(fc/f)²)",
            "For TM modes: Z_w = η×√(1-(fc/f)²)",
            "η = √(μ/ε) = intrinsic impedance",
            "At f >> fc: Z_w ≈ η"
          ],
          "formula": "Z_TE = η/√(1-(fc/f)²), Z_TM = η√(1-(fc/f)²)"
        }
      ],
      "numericalProblems": [
        {
          "question": "Find cutoff frequency for WR-90 waveguide (a=0.9\", b=0.4\")",
          "given": "a = 0.9 inch = 0.02286 m, c = 3×10⁸ m/s",
          "solution": "fc = c/(2a) = 3×10⁸/(2×0.02286) = 6.56 GHz",
          "answer": "6.56 GHz"
        },
        {
          "question": "Calculate guide wavelength λg at f=10 GHz for a=2.286 cm waveguide",
          "given": "a = 2.286 cm, f = 10 GHz, fc = c/(2a) = 6.56 GHz",
          "solution": "λg = λ/√(1-(fc/f)²) = (3×10⁸/10⁹)/√(1-(6.56/10)²) = 3.6 cm",
          "answer": "3.6 cm"
        },
        {
          "question": "Find S-parameters for a lossless transmission line of length l",
          "given": "Characteristic impedance Z₀, electrical length θ=βl",
          "solution": "S₁₁ = S₂₂ = 0 (matched), S₂₁ = S₁₂ = e^(-jθ) (transmission)",
          "answer": "S-matrix = [[0, e^(-jθ)], [e^(-jθ), 0]]"
        }
      ],
      "quiz": [
