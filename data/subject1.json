    {
      "id": 2,
      "title": "Microwave Passive Components",
      "audio": "assets/audio/subject1/chap2.mp3",
      "duration": "22 mins",
      "keyPoints": [
        "Directional Couplers",
        "Circulators & Isolators",
        "Attenuators & Phase Shifters"
      ],
      "content": "Microwave passive components help split, combine, or control microwave signals without adding power. They are like water pipes with valves and splitters.",
      "derivations": [
        {
          "title": "S-Matrix for Directional Coupler",
          "steps": [
            "4-port network: input, output, coupled, isolated",
            "Forward coupling: S₃₁ = C (coupling factor)",
            "Through path: S₂₁ = T (transmission)",
            "Isolation: S₄₁ = 0 (ideal)",
            "Reciprocity: Sᵢⱼ = Sⱼᵢ"
          ],
          "formula": "|S₃₁|² = coupling, |S₂₁|² = 1-coupling (ideal)"
        },
        {
          "title": "VSWR from Reflection Coefficient",
          "steps": [
            "Reflection coefficient: Γ = (ZL-Z₀)/(ZL+Z₀)",
            "VSWR = (1+|Γ|)/(1-|Γ|)",
            "Return loss = -20log|Γ| dB",
            "For perfect match: Γ=0, VSWR=1"
          ],
          "formula": "VSWR = (1+|Γ|)/(1-|Γ|), RL = -20log₁₀|Γ| dB"
        },
        {
          "title": "Insertion Loss",
          "steps": [
            "IL = 10log₁₀(P_in/P_out) dB",
            "IL = 10log₁₀(1/|S₂₁|²) dB",
            "For coupler: IL = -10log₁₀(1-|C|²)",
            "Mismatch loss also contributes"
          ],
          "formula": "IL = 10log₁₀(1/|S₂₁|²) dB"
        },
        {
          "title": "Phase Shifter Group Delay",
          "steps": [
            "Phase shift φ = βl = (2π/λg)l",
            "Group delay τg = dφ/dω = l/vg",
            "For f=10 GHz, l=λg/4: φ = 90°",
            "Electrical length: θ = βl radians"
          ],
          "formula": "τg = dφ/dω = l/vg = l√(1-(fc/f)²)/c"
        },
        {
          "title": "Wilkinson Power Divider",
          "steps": [
            "2-way divider with isolation resistors",
            "Input matched: Z_in = Z₀",
            "Output ports isolated: S₃₂ = 0",
            "Power division: P₂ = P₃ = P₁/2"
          ],
          "formula": "Z_in = Z₀, P_out = P_in/2 (3 dB split)"
        }
      ],
      "numericalProblems": [
        {
          "question": "Design 10 dB directional coupler (find coupling, isolation)",
          "given": "C = 10 dB = 0.1 (linear), P_coupled/P_in = 0.1",
          "solution": "Coupling = 10log₁₀(0.1) = -10 dB, Through = 10log₁₀(0.9) = -0.46 dB",
          "answer": "Coupling = -10 dB, Through = -0.46 dB"
        },
        {
          "question": "Find VSWR given return loss = 20 dB",
          "given": "RL = 20 dB → |Γ| = 10^(-20/20) = 0.1",
          "solution": "VSWR = (1+0.1)/(1-0.1) = 1.22",
          "answer": "VSWR = 1.22:1"
        }
      ],
      "quiz": [
        {
          "q": "What is VSWR formula?",
          "options": ["(1+|Γ|)/(1-|Γ|)", "(1-|Γ|)/(1+|Γ|)", "1+|Γ|"],
          "answer": 0
        }
      ],
      "pdfSources": [
        "Pozar - Microwave Engineering (Ch 7)",
        "RF & Microwave Engineering PDF - Unit 7"
      ],
      "tanglishNotes": "Indha directional coupler-la, signal-a split pannum. Oru part direct pokum, inoru part coupled port-ku pokum. VSWR na vala signal reflect aagudhu nu katurudhu."
    },
