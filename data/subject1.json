          "answer": 0
        },
        {
          "q": "Which velocity is faster than light in waveguides?",
          "options": ["Phase velocity", "Group velocity", "Both are same"],
          "answer": 0
        },
        {
          "q": "What is characteristic impedance Z₀ formula?",
          "options": ["Z₀ = √(L/C)", "Z₀ = L/C", "Z₀ = √(LC)"],
          "answer": 0
        }
      ],
      "pdfSources": [
        "Pozar - Microwave Engineering 4th Ed (Ch 3, 4)",
