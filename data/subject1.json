      "content": "Microwave generators create high-frequency signals. Klystrons use electron beams, Magnetrons create microwaves for ovens, TWTs amplify signals over wide bandwidths.",
      "derivations": [
        {
          "title": "Small-Signal Gain for BJT at Microwave",
          "steps": [
            "S₂₁ = forward transmission coefficient",
            "|S₂₁|² = power gain (linear)",
            "Gain(dB) = 20log₁₀|S₂₁|",
            "For unmatched: G = |S₂₁|²/(1-|S₁₁|²)"
          ],
          "formula": "Gain(dB) = 20log₁₀|S₂₁|"
        },
        {
          "title": "Stability Factor K",
          "steps": [
            "K = (1-|S₁₁|²-|S₂₂|²-|Δ|²)/(2|S₁₂S₂₁|)",
            "Δ = S₁₁S₂₂ - S₁₂S₂₁",
            "K > 1 and |Δ| < 1 → Unconditionally stable",
            "K < 1 → Potentially unstable"
          ],
          "formula": "K = (1-|S₁₁|²-|S₂₂|²-|Δ|²)/(2|S₁₂S₂₁|)"
        },
        {
          "title": "Output Power for Class A Amplifier",
          "steps": [
            "P_out = (V_Cc - V_sat)²/(2R_L)",
            "Collector efficiency: η = P_out/P_DC",
            "P_DC = V_Cc × I_Cq",
            "Max efficiency = 50% for Class A"
          ],
          "formula": "P_out = (V_cc - V_sat)²/(2R_L), η = P_out/(V_cc×I_cq)"
        },
        {
          "title": "Transit Time Effects in Gunn Diodes",
          "steps": [
            "Gunn effect: transferred electron effect",
            "Negative differential resistance (NDR)",
            "Oscillation frequency: f = v_d/(2L) for domain",
            "v_d = drift velocity, L = active region length"
          ],
          "formula": "f_osc = v_d/(2L)"
        },
        {
          "title": "Two-Port Power Gain",
          "steps": [
            "Transducer gain: G_T = P_L/(available from source)",
            "Available power: P_avs = |V_s|²/(8R_s)",
            "G_T = (|S₂₁|²(1-|Γ_s|²)(1-|Γ_L|²))/(|(1-S₁₁Γ_s)(1-S₂₂Γ_L) - S₁₂S₂₁Γ_sΓ_L|²)",
            "For matched: Γ_s = Γ_L = 0 → G_T = |S₂₁|²"
          ],
          "formula": "G_T = |S₂₁|² for matched input/output"
        }
      ],
      "numericalProblems": [
        {
