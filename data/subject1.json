    {
      "id": 4,
      "title": "Microwave Measurements & Propagation",
      "audio": "assets/audio/subject1/chap4.mp3",
      "duration": "26 mins",
      "keyPoints": [
        "S-Parameter Measurements",
        "Smith Chart Impedance Matching",
        "Link Budget Analysis"
      ],
      "content": "Measuring microwaves needs special tools like network analyzers. Smith chart is a graphical tool that helps match impedances. Link budget calculates how much power reaches the receiver.",
      "derivations": [
        {
          "title": "Reflection Coefficient Γ",
          "steps": [
            "Γ = (ZL-Z₀)/(ZL+Z₀)",
            "For open circuit: ZL=∞ → Γ=+1",
            "For short circuit: ZL=0 → Γ=-1",
            "For matched load: ZL=Z₀ → Γ=0"
          ],
          "formula": "Γ = (ZL-Z₀)/(ZL+Z₀) = |Γ|e^(jθ)"
        },
        {
          "title": "Transmission Coefficient T",
          "steps": [
            "T = VL/VS = 2ZL/(ZL+Z₀) for voltage",
            "Power transmission: τ = PL/Pin = 1-|Γ|²",
            "For lossless: |T|² = 1-|Γ|²",
            "Insertion loss = -10log₁₀|T|²"
          ],
          "formula": "T = 2ZL/(ZL+Z₀), τ = 1-|Γ|²"
        },
        {
          "title": "Smith Chart Transformations",
          "steps": [
            "Impedance to admittance: rotate 180°",
            "z = Z/Z₀ = (1+Γ)/(1-Γ)",
            "y = Y/Y₀ = (1-Γ)/(1+Γ)",
            "Adding reactance: move along constant |Γ| circle"
          ],
          "formula": "z = (1+Γ)/(1-Γ), y = 1/z"
        },
        {
          "title": "Friis Link Budget Equation",
          "steps": [
            "P_r = P_t × G_t × G_r × (λ/(4πd))²",
            "Path loss: L_fs = (4πd/λ)²",
            "In dB: P_r(dBm) = P_t(dBm) + G_t(dB) + G_r(dB) - L_fs(dB)",
            "L_fs(dB) = 20log₁₀(d) + 20log₁₀(f) - 147.55"
          ],
          "formula": "P_r = P_t G_t G_r (λ/4πd)²"
        },
        {
          "title": "Return Loss",
          "steps": [
            "RL = -20log₁₀|Γ| dB",
            "For VSWR = 2: |Γ| = (2-1)/(2+1) = 1/3",
            "RL = -20log₁₀(1/3) = 9.54 dB",
            "Better match → higher return loss"
          ],
          "formula": "RL(dB) = -20log₁₀|Γ| = 20log₁₀(VSWR+1)/(VSWR-1)"
        }
      ],
      "numericalProblems": [
        {
          "question": "Use Smith chart to match 50Ω to 75Ω at 1 GHz",
          "given": "Z_in = 50Ω, Z_L = 75Ω, normalize: z_L = 75/50 = 1.5",
          "solution": "Use stub matching: add inductive stub at d/λg = 0.125 from load",
          "answer": "Stub position: 0.125λg from load"
        },
        {
          "question": "Calculate received power for P_t=1W, G_t=20 dBi, G_r=20 dBi, d=10 km, f=2.4 GHz",
          "given": "L_fs = 20log₁₀(10⁴) + 20log₁₀(2.4×10⁹) - 147.55 = 40 + 67.6 - 147.55 = -39.95 dB",
          "solution": "P_r = 30 + 20 + 20 - 39.95 = 30.05 dBm = 1 W",
          "answer": "P_r = 1 W (30.05 dBm)"
        }
      ],
      "quiz": [
        {
          "q": "What is Friis link budget equation?",
          "options": ["P_r = P_t×G_t×G_r×(λ/4πd)²", "P_r = P_t/(G_t×G_r)", "P_r = P_t×d²"],
          "answer": 0
        }
      ],
      "pdfSources": [
        "Pozar - Microwave Engineering (Ch 6)",
        "RF & Microwave Engineering PDF - Unit 6"
      ],
      "tanglishNotes": "Smith chart-ula impedence match pannalam. Link budget-na: sender-ku evlo power kudukuranu, receiver-ku evlo kedaikudhu nu calculate pannudhu. Free space path loss formula: L = (4πd/λ)²."
    },
