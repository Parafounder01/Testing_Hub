        "Stripline & Coplanar",
        "MIC & MMIC"
      ],
      "content": "Microwave Integrated Circuits (MIC) put components on a single substrate. Microstrip lines are like tiny transmission lines on PCB. They're used in cell phones and WiFi devices.",
      "derivations": [
        {
          "title": "Microstrip Characteristic Impedance",
          "steps": [
            "For W/h > 1: Z₀ = (87/√(εᵣ+1.41))ln(5.98h/W)",
            "For W/h < 1: Z₀ = (60/√(εᵣ))ln(8h/W + W/4h)",
            "εᵣ = (εᵣ+1)/2 + (εᵣ-1)/2×(1+12h/W)^(-1/2)",
            "Effective dielectric constant"
          ],
          "formula": "Z₀ = (87/√(εᵣ+1.41))ln(5.98h/W) for W/h > 1"
        },
        {
          "title": "Effective Dielectric Constant",
          "steps": [
            "ε_eff = (εᵣ+1)/2 + (εᵣ-1)/2×(1+12h/W)^(-1/2)",
            "For wide strips: ε_eff ≈ (εᵣ+1)/2",
            "Phase velocity: vp = c/√ε_eff",
            "Wavelength: λg = λ₀/√ε_eff"
          ],
          "formula": "ε_eff = (εᵣ+1)/2 + (εᵣ-1)/2×(1+12h/W)^(-1/2)"
        },
        {
          "title": "Attenuation in Microstrip",
          "steps": [
            "Conductor loss: α_c = Rs/(Z₀W) nepers/m",
            "Rs = √(πfμ/σ) = surface resistance",
            "Dielectric loss: α_d = (π/λ)×(εᵣ/ε_eff)×(ε_eff-1)/(εᵣ-1)×tanδ",
            "Total: α = α_c + α_d"
          ],
          "formula": "α_c = Rs/(Z₀W) Np/m, Rs = √(πfμ/σ)"
        },
        {
          "title": "Coupled Line Even/Odd Mode",
          "steps": [
            "Even mode: Z₀e = Z₀(1+C) (higher impedance)",
            "Odd mode: Z₀o = Z₀(1-C) (lower impedance)",
            "Coupling: C = (Z₀e-Z₀o)/(Z₀e+Z₀o)",
            "For directional coupler: C = 10^(-C_dB/20)"
          ],
          "formula": "C = (Z₀e-Z₀o)/(Z₀e+Z₀o)"
        },
        {
          "title": "Butterworth Filter Design",
          "steps": [
            "Low-pass prototype: |H(jω)|² = 1/(1+ω²ⁿ)",
            "For n=3: poles at 60° intervals",
            "g₀=g₄=1, g₁=g₃=2sin(π/2n), g₂=2sin(π/2n) for n=3",
            "Transform to bandpass/bandstop"
          ],
          "formula": "|H(jω)|² = 1/(1+(ω/ωc)²ⁿ) for Butterworth"
        }
      ],
      "numericalProblems": [
        {
          "question": "Design 50Ω microstrip on FR4 (εᵣ=4.4, h=1.6mm), find W",
          "given": "For Z₀=50Ω, use Z₀ ≈ 60/√εᵣ × ln(8h/W) → W/h ≈ 2",
          "solution": "W = 2×1.6 = 3.2 mm (approximate)",
          "answer": "W ≈ 3.2 mm"
        },
        {
          "question": "Calculate guide wavelength at 2.4 GHz on Rogers RO4350 (εᵣ=3.48)",
          "given": "ε_eff ≈ (3.48+1)/2 = 2.24, λg = λ₀/√ε_eff = 12.5/1.5 = 8.33 cm",
          "solution": "λg = 8.33 cm at 2.4 GHz",
          "answer": "8.33 cm"
        }
      ],
      "quiz": [
        {
          "q": "What is microstrip effective dielectric constant formula?",
          "options": ["ε_eff = (εᵣ+1)/2 + (εᵣ-1)/2×(1+12h/W)^(-1/2)", "ε_eff = εᵣ", "ε_eff = 1"],
          "answer": 0
        }
      ],
      "pdfSources": [
        "Pozar - Microwave Engineering (Ch 7)",
        "RF & Microwave Engineering PDF - Unit 10"
      ],
      "tanglishNotes": "Indha microstrip line-oda, PCB melaya trace potu microwave signal-a poga vaikalam. Z₀ = 50Ω-nu calculate pannalam. ε_eff na effective dielectric constant. Indha RO4350 board-la 8.33 cm wavelength kedaikum."
