          ],
          "formula": "I_D = (μ_nC_ox/2)(W/L)(V_GS-V_th)²"
        },
        {
          "title": "JFET Pinch-off Voltage",
          "steps": [
            "V_p = (eN_d/2ε_s)×a² (for abrupt junction)",
            "a = channel radius",
            "N_d = donor concentration (n-channel)",
            "I_D = I_DSS(1 - V_GS/V_p)² (Shockley equation)",
            "Pinch-off: V_GS = V_p → I_D = 0"
          ],
          "formula": "V_p = (eN_d/2ε_s)×a²"
        },
        {
          "title": "SCR Turn-on Condition",
          "steps": [
            "Latching current I_L > holding current I_H",
            "Forward bias: anode-to-cathode voltage > 0.7V",
            "Gate current triggers turn-on",
