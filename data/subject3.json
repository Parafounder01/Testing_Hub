      "content": "Power circuits supply clean DC voltage. Zener diode limits voltage like a pressure relief valve. SMPS uses switches for high efficiency. Rectifiers convert AC to DC.",
      "derivations": [
        {
          "title": "Zener Regulator Design",
          "steps": [
            "V_out = V_Z (Zener voltage)",
            "I_Z(min) < I_Z < I_Z(max) for regulation",
            "R_S = (V_in - V_Z)/(I_L + I_Z)",
            "P_Z = V_Z × I_Z(max) (Zener power rating)",
            "Line regulation = ΔV_out/ΔV_in"
          ],
          "formula": "R_S = (V_in - V_out)/(I_L + I_Z)"
        },
        {
          "title": "SMPS Buck Converter",
          "steps": [
            "V_out = D×V_in (duty cycle D)",
            "D = t_on/T (switch on time/total period)",
            "ΔI_L = (V_in-V_out)×D×T/L",
            "Output ripple: ΔV_out ≈ ΔI_L×ESR",
            "Efficiency η > 85% (much better than linear)"
          ],
          "formula": "V_out = D×V_in, D = t_on/T"
        },
        {
          "title": "Rectifier Ripple Voltage",
          "steps": [
            "Full-wave bridge: V_ripple = I_L/(2fC)",
            "Half-wave: V_ripple = I_L/(fC)",
            "V_DC ≈ V_peak - V_ripple/2",
            "Capacitor stores energy between peaks",
            "Larger C → smaller ripple"
          ],
          "formula": "V_ripple = I_L/(2fC) [full-wave], I_L/(fC) [half-wave]"
        },
        {
          "title": "Regulator Efficiency",
          "steps": [
            "η = P_out/P_in = (V_out×I_L)/(V_in×I_in)",
            "Linear regulator: η = V_out/V_in (low, ~50%)",
            "SMPS: η > 85% (high efficiency)",
            "Power dissipation: P_D = (V_in-V_out)×I_L",
            "Heat sink needed for large P_D"
          ],
          "formula": "η = V_out/V_in [linear], >85% [SMPS]"
        },
        {
          "title": "Current Limiting (Protection)",
          "steps": [
            "Sense resistor: V_sense = I_L×R_sense",
            "When V_sense > V_BE: transistor turns on",
            "Limits I_L(max) = V_BE/R_sense",
            "Typical V_BE = 0.7V for silicon",
            "Protects regulator from overcurrent"
          ],
          "formula": "I_L(max) = V_BE/R_sense"
        }
      ],
