          "title": "Schmitt Trigger Thresholds",
          "steps": [
            "V_T+ = βV_cc (upper threshold)",
            "V_T- = β'V_cc (lower threshold)",
            "β = R₁/(R₁+R₂) (voltage divider)",
            "Hysteresis = V_T+ - V_T-",
