          "formula": "R = k₁λ/NA"
        },
        {
          "title": "Oxidation Rate (Deal-Grove Model)",
          "steps": [
            "Parabolic: x² = B(t+τ) for thick oxide",
            "Linear: x = B/A·t for thin oxide",
            "B = parabolic rate constant",
            "A = linear rate constant",
            "τ = time shift (initial rapid growth)"
          ],
          "formula": "x² = B(t+τ) [parabolic], x = (B/A)t [linear]"
        },
        {
          "title": "Diffusion Profile (Constant Source)",
          "steps": [
            "C(x,t) = C₀erfc(x/√(4Dt))",
            "C₀ = surface concentration",
            "D = diffusion coefficient",
            "erfc = complementary error function",
            "J = -D∂C/∂x (Fick's first law)"
          ],
          "formula": "C(x,t) = C₀erfc(x/√(4Dt))"
        },
        {
          "title": "CMOS Inverter Delay",
          "steps": [
