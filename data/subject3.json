      "content": "Digital circuits use 0s and 1s. Boolean algebra is math with YES/NO. Karnaugh map is a picture puzzle to simplify logic. Flip-flops are switches with memory.",
      "derivations": [
        {
          "title": "Boolean Algebra Laws",
          "steps": [
            "Commutative: A+B = B+A, A·B = B·A",
            "Associative: (A+B)+C = A+(B+C)",
            "Distributive: A+(B·C) = (A+B)·(A+C)",
            "De Morgan: (A+B)' = A'·B', (A·B)' = A'+B'",
            "Absorption: A+(A·B) = A, A·(A+B) = A"
          ],
          "formula": "De Morgan: (A+B)' = A'·B'"
        },
        {
          "title": "Karnaugh Map Simplification",
          "steps": [
            "F = Σ(0,2,4,6) for 3-variable K-map",
            "Group adjacent 1s in powers of 2",
            "Group 1: m0+m2 = A'B'C'+A'BC' = A'C'",
            "Group 2: m4+m6 = AB'C'+ABC' = BC'",
            "F = A'C' + BC' = C'(A'+B)"
          ],
          "formula": "F = Σ(minterms) → group → simplified expression"
        },
        {
          "title": "Flip-Flop Characteristic Equations",
          "steps": [
            "D-FF: Q⁺ = D (next state = D input)",
            "JK-FF: Q⁺ = JQ' + K'Q",
            "SR-FF: Q⁺ = S + R'Q (with SR=0 constraint)",
            "T-FF: Q⁺ = T⊕Q = TQ' + T'Q",
            "Clocked: changes only on clock edge"
          ],
          "formula": "JK-FF: Q⁺ = JQ' + K'Q"
        },
        {
          "title": "Counter Modulus",
          "steps": [
            "n-bit counter: modulus M = 2ⁿ",
            "MOD-16 counter: n=4, M=16 states",
            "Frequency division: f_out = f_clk/2ⁿ",
            "Decade counter: M=10 (uses 4 bits)",
            "Design: connect Q to reset when count=9"
          ],
          "formula": "M = 2ⁿ for n-bit counter"
        },
        {
          "title": "Setup & Hold Time",
          "steps": [
            "t_setup: data must be stable BEFORE clock edge",
            "t_hold: data must be stable AFTER clock edge",
            "Clock period: T_clk > t_cq(max) + t_setup + t_logic",
            "Max frequency: f_max = 1/T_clk",
            "Violation → metastability"
          ],
          "formula": "T_clk > t_cq(max) + t_logic + t_setup"
        }
