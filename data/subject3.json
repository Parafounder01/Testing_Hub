          "formula": "I_D = I_S(e^(V_D/nV_T)-1)"
        },
        {
          "title": "BJT Current Gain",
          "steps": [
            "β = I_C/I_B (DC current gain)",
            "α = I_C/I_E = β/(β+1)",
            "I_C = βI_B + (β+1)I_CBO",
            "For large β: I_C ≈ βI_B",
            "I_E = I_B + I_C = (β+1)I_B"
          ],
          "formula": "β = I_C/I_B, α = β/(β+1)"
        },
        {
          "title": "MOSFET Drain Current (Saturation)",
          "steps": [
            "I_D = (μ_nC_ox/2)(W/L)(V_GS-V_th)²",
